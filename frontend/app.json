{
  "expo": {
    "name": "Muse",
    "slug": "frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "muse",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Record your voice for instant motivation",
        "NSCameraUsageDescription": "Capture a moment to inspire your quote",
        "NSPhotoLibraryUsageDescription": "Pick a photo to inspire your quote"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#121110"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "RECORD_AUDIO",
        "CAMERA",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#121110"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Pick a photo to inspire your quote",
          "cameraPermission": "Capture a moment to inspire your quote"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
